# =========================================================
# SECRETS — NEVER COMMIT THESE
# =========================================================

# SSH private keys (any name, any format)
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
id_dsa
id_dsa.pub
*.pem
*.key
*_key
*_key.pub
*.ppk
takima_key
takima_key.pub

# Known hosts / auth
.ssh/
known_hosts

# Environment files with secrets
.env
.env.local
.env.*.local
*.env

# Ansible vault — decrypted versions (the encrypted one is safe to commit)
*vault.decrypted*
*.vault-password
.vault_pass
.vault_password

# Cloud / Docker credentials
.aws/
.docker/config.json
.kube/config

